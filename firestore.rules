rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /overrides/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /custom/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
